{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Compile and Run C",
            "type": "shell",
            "command": "gcc",
            "args": [
                "-g",
                "${file}",
                "-o",
                "${fileDirname}/${fileBasenameNoExtension}.exe"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": ["$msCompile"],
            "detail": "컴파일 후 실행 파일 생성",
            "runOptions": {
                "runOn": "folderOpen"
            }
        }
    ]
}